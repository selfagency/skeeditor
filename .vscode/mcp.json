{
  "servers": {
    "git": {
      "command": "npx",
      "args": ["-y", "@selfagency/git-mcp@latest", "--repo-path", "${workspaceFolder}"]
    },
    "tasks": {
      "command": "mcp-taskfile-server",
      "type": "stdio"
    },
    "browsermcp": {
      "command": "npx",
      "args": ["@browsermcp/mcp@latest"]
    }
  }
}
