{
  "version": "0.2.0",
  "configurations": [
    // ─────────────────────────────────────────────────────────────────────────
    // 1. Build-and-debug: launch Chrome with the unpacked extension pre-loaded.
    //    Breaks into TypeScript sources courtesy of source maps.
    //    Prereq: runs the "Build Chrome (watch)" task automatically.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Chrome Extension (launch)",
      "type": "chrome",
      "request": "launch",
      "url": "https://bsky.app",
      "runtimeExecutable": "/Applications/Chromium.app/Contents/MacOS/Chromium",
      "runtimeArgs": [
        "--load-extension=${workspaceFolder}/dist/chrome",
        "--disable-extensions-except=${workspaceFolder}/dist/chrome",
        // Keeps a stable profile across sessions so you stay logged in.
        "--user-data-dir=${workspaceFolder}/.chromium-debug-profile"
      ],
      "preLaunchTask": "Build Chrome (watch)",
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/dist/chrome/**/*.js"
      ],
      // Only resolve source maps from the extension's own output — suppresses
      // noisy "Could not read source map" warnings from hls.js and other
      // third-party scripts served by bsky.app.
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist/chrome/**",
        "!**/node_modules/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**",
        "${workspaceFolder}/src/lexicons/**"
      ],
      "presentation": {
        "group": "chrome-extension",
        "order": 1
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 2. Attach to an already-running Chromium instance that was launched with
    //    --remote-debugging-port=9222. Useful when you want to keep your own
    //    Chromium session / cookies.
    //
    //    Launch Chromium manually first:
    //    open -na "Chromium" --args \
    //      --remote-debugging-port=9222 \
    //      --user-data-dir=/tmp/chromium-debug \
    //      --load-extension=<absolute-path>/dist/chrome
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Chrome Extension (attach)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "https://bsky.app/*",
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/dist/chrome/**/*.js"
      ],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist/chrome/**",
        "!**/node_modules/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**",
        "${workspaceFolder}/src/lexicons/**"
      ],
      "presentation": {
        "group": "chrome-extension",
        "order": 2
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 3. Debug the service worker (background script).
    //    Attaches to the extension's service-worker target specifically.
    //    The service worker URL pattern:
    //      chrome-extension://<extension-id>/background.js
    //    Replace <EXTENSION_ID> below with the value from chrome://extensions
    //    after loading the unpacked extension, or use the wildcard pattern.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Service Worker (attach)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "targetSelection": "pick",
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/dist/chrome/background.js",
        "${workspaceFolder}/dist/chrome/chunks/*.js"
      ],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist/chrome/**",
        "!**/node_modules/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "presentation": {
        "group": "chrome-extension",
        "order": 3
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 4. Debug the popup page.
    //    After attaching, open the popup from the Chrome toolbar — DevTools
    //    will capture the context automatically.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Popup (attach)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "chrome-extension://*/popup.html",
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/dist/chrome/**/*.js"
      ],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist/chrome/**",
        "!**/node_modules/**"
      ],
      "presentation": {
        "group": "chrome-extension",
        "order": 4
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 5. Debug content script on bsky.app.
    //    This is the most useful config for tracking down why the edit button
    //    isn't appearing — set breakpoints in:
    //      src/content/post-detector.ts  — findPosts / extractPostInfo
    //      src/content/content-script.ts — addEditButton / scheduleScan
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Content Script on bsky.app (attach)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "https://bsky.app/*",
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/dist/chrome/content-scripts/*.js"
      ],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist/chrome/content-scripts/**",
        "!**/node_modules/**"
      ],
      "pathMapping": {
        "/src/": "${workspaceFolder}/src/"
      },
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**",
        "${workspaceFolder}/src/lexicons/**"
      ],
      "presentation": {
        "group": "chrome-extension",
        "order": 5
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 6. General web debugger — attach to bsky.app tab in the running Chromium
    //    (port 9222) and open the VS Code debug console immediately.
    //    Use this to evaluate JS expressions in the page context, inspect the
    //    DOM, and call window.__skeeditor* helpers without needing DevTools.
    //    Start the session by pressing F5 while this config is selected; type
    //    expressions in the "Debug Console" panel (Ctrl+Shift+Y / ⇧⌘Y).
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: bsky.app Web Console (attach)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      // No url filter — attaches to the first available page target.
      // Use targetSelection: "pick" if you want to choose a specific tab.
      "targetSelection": "pick",
      "preLaunchTask": "Open Chromium (remote debug on 9222)",
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src",
      "outFiles": [
        "${workspaceFolder}/dist/chrome/**/*.js"
      ],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist/chrome/**",
        "!**/node_modules/**"
      ],
      "internalConsoleOptions": "openOnSessionStart",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**",
        "${workspaceFolder}/src/lexicons/**"
      ],
      "presentation": {
        "group": "chrome-extension",
        "order": 6
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 7. Vitest unit tests — debug a single test file.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Vitest (unit)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "exec",
        "vitest",
        "--project",
        "unit",
        "--reporter=verbose"
      ],
      "console": "integratedTerminal",
      "sourceMaps": true,
      "presentation": {
        "group": "tests",
        "order": 6
      }
    },
    // ─────────────────────────────────────────────────────────────────────────
    // 7. Vitest integration tests.
    // ─────────────────────────────────────────────────────────────────────────
    {
      "name": "Debug: Vitest (integration)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "exec",
        "vitest",
        "--project",
        "integration",
        "--reporter=verbose"
      ],
      "console": "integratedTerminal",
      "sourceMaps": true,
      "presentation": {
        "group": "tests",
        "order": 7
      }
    }
  ],
  // ─────────────────────────────────────────────────────────────────────────
  // Compound: build + launch Chrome + attach content-script debugger in one go.
  // ─────────────────────────────────────────────────────────────────────────
  "compounds": [
    {
      "name": "Debug: Full Extension (build + launch)",
      "configurations": [
        "Debug: Chrome Extension (launch)"
      ],
      "stopAll": true,
      "presentation": {
        "group": "chrome-extension",
        "order": 0
      }
    },
    // Attach web console + content-script debugger to already-running Chromium.
    // Requires Chromium launched with --remote-debugging-port=9222.
    {
      "name": "Debug: Attach to Running Extension",
      "configurations": [
        "Debug: bsky.app Web Console (attach)",
        "Debug: Content Script on bsky.app (attach)"
      ],
      "stopAll": true,
      "presentation": {
        "group": "chrome-extension",
        "order": 1
      }
    }
  ]
}