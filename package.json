{
  "name": "skeeditor",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-browser Bluesky post editor extension.",
  "keywords": [
    "atproto",
    "bluesky",
    "browser-extension",
    "monorepo"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:repo": "turbo run build",
    "build:watch": "tsx scripts/build.ts --watch",
    "clean": "node -e \"import('node:fs/promises').then(fs => Promise.all(['.turbo', 'coverage', 'dist', 'playwright-report', 'test-results'].map(path => fs.rm(path, { force: true, recursive: true }))))\"",
    "dev": "pnpm run build:watch",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "manifest:chrome": "tsx scripts/merge-manifest.ts chrome",
    "manifest:firefox": "tsx scripts/merge-manifest.ts firefox",
    "manifest:safari": "tsx scripts/merge-manifest.ts safari",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium-extension",
    "test:e2e:firefox": "playwright test --project=firefox-extension",
    "test:e2e:list": "playwright test --list",
    "test:integration": "vitest run --project integration",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest --project unit --project integration",
    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^24.5.2",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "msw": "^2.11.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsx": "^4.20.5",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "web-ext": "^8.8.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}