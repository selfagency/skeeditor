{
  "name": "skeeditor",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-browser Bluesky post editor extension.",
  "keywords": [
    "atproto",
    "bluesky",
    "browser-extension",
    "monorepo"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm run lex:build && tsx scripts/build.ts --browser=chrome",
    "build:chrome": "pnpm run lex:build && tsx scripts/build.ts --browser=chrome",
    "build:firefox": "pnpm run lex:build && tsx scripts/build.ts --browser=firefox",
    "build:safari": "pnpm run lex:build && tsx scripts/build.ts --browser=safari",
    "build:repo": "pnpm run build:chrome && pnpm run build:firefox && pnpm run build:safari",
    "build:watch": "tsx scripts/build.ts --browser=chrome --watch",
    "build:watch:chrome": "tsx scripts/build.ts --browser=chrome --watch",
    "build:watch:firefox": "tsx scripts/build.ts --browser=firefox --watch",
    "build:watch:safari": "tsx scripts/build.ts --browser=safari --watch",
    "clean": "tsx scripts/clean.ts",
    "dev": "pnpm run build:watch:chrome",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lex:build": "pnpm exec lex build --clear --lexicons ./lexicons --out ./src/lexicons && tsx scripts/prepare-generated-lexicons.ts",
    "lex:install": "pnpm exec lex install app.bsky.feed.post app.bsky.actor.profile com.atproto.repo.createRecord com.atproto.repo.deleteRecord com.atproto.repo.describeRepo com.atproto.repo.getRecord com.atproto.repo.listRecords com.atproto.repo.putRecord com.atproto.repo.uploadBlob",
    "lex:sync": "pnpm run lex:install && pnpm run lex:build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "manifest:chrome": "tsx scripts/merge-manifest.ts chrome",
    "manifest:firefox": "tsx scripts/merge-manifest.ts firefox",
    "manifest:safari": "tsx scripts/merge-manifest.ts safari",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium-extension",
    "test:e2e:firefox": "playwright test --project=firefox-extension",
    "test:e2e:list": "playwright test --list",
    "test:integration": "vitest run --project integration",
    "test:unit": "pnpm run lex:build && vitest run --project unit",
    "test:watch": "vitest --project unit --project integration",
    "typecheck": "pnpm run lex:build && tsc --project tsconfig.build.json --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "dependencies": {
    "@atproto/lex": "^0.0.22",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "25.5.0",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "4.1.1",
    "husky": "^9.1.7",
    "jsdom": "29.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.2",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitepress": "^1.6.4",
    "vitest": "4.1.1",
    "web-ext": "10.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
